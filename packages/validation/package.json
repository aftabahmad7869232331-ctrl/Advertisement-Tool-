{
    "name":  "@bricks-maker/validation",
    "version":  "0.1.0",
    "private":  true,
    "description":  "Shared validation schemas",
    "type":  "module",
    "main":  "./dist/index.js",
    "types":  "./dist/index.d.ts",
    "exports":  {
                    ".":  {
                              "types":  "./dist/index.d.ts",
                              "import":  "./dist/index.js"
                          }
                },
    "files":  [
                  "dist"
              ],
    "scripts":  {
                    "build":  "tsc -p tsconfig.json",
                    "typecheck":  "tsc --noEmit",
                    "test":  "vitest run",
                    "clean":  "powershell -NoProfile -Command \"if (Test-Path dist) { Remove-Item dist -Recurse -Force }\""
                }
}
