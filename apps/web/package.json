{
  "name": "@bricks-maker/web",
  "version": "0.1.0",
  "private": true,
  "description": "Main user-facing frontend for Bricks Maker Advertisement Studio.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
