{
  "name": "@bricks-maker/api",
  "version": "0.1.0",
  "private": true,
  "description": "Main backend API for Bricks Maker Advertisement Studio.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings=0",
    "test": "vitest run",
    "clean": "powershell -NoProfile -Command \"if (Test-Path dist) { Remove-Item dist -Recurse -Force }\""
  },
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "@fastify/helmet": "^13.1.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.10.0",
    "zod": "^4.4.3"
  }
}
