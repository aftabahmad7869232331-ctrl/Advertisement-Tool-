# =========================================================
# Bricks Maker Advertisement Studio
# Environment Variable Template
# =========================================================

# -------------------------
# Application
# -------------------------
NODE_ENV=development
APP_NAME=Bricks Maker Advertisement Studio
APP_URL=http://localhost:5173

# -------------------------
# Frontend
# Only public, non-secret values may use VITE_ prefix.
# -------------------------
VITE_APP_NAME=Bricks Maker Advertisement Studio
VITE_API_BASE_URL=http://localhost:3000/api
VITE_MAX_VIDEO_DURATION_SECONDS=30
VITE_STUDIO_SEGMENT_COUNT=5
VITE_STUDIO_SEGMENT_DURATION_SECONDS=6

# -------------------------
# API Server
# -------------------------
API_HOST=127.0.0.1
API_PORT=3000
API_BASE_PATH=/api
CORS_ORIGIN=http://localhost:5173

# -------------------------
# Authentication
# Replace placeholder values only in local .env
# -------------------------
JWT_ACCESS_SECRET=replace-with-local-secret
JWT_REFRESH_SECRET=replace-with-local-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# -------------------------
# Database
# -------------------------
DATABASE_URL=postgresql://username:password@localhost:5432/bricks_maker_studio

# -------------------------
# Queue
# -------------------------
QUEUE_PROVIDER=redis
REDIS_URL=redis://127.0.0.1:6379
RENDER_QUEUE_NAME=render-jobs
AI_QUEUE_NAME=ai-jobs

# -------------------------
# Local Storage
# -------------------------
UPLOAD_DIRECTORY=./storage/uploads
PROJECT_DIRECTORY=./storage/projects
RENDER_DIRECTORY=./storage/renders
PREVIEW_DIRECTORY=./storage/previews
TEMP_DIRECTORY=./storage/temp
MODEL_DIRECTORY=./storage/models

# -------------------------
# Upload and Render Limits
# -------------------------
MAX_UPLOAD_SIZE_MB=500
MAX_VIDEO_DURATION_SECONDS=10
MAX_PROMPTS_PER_JOB=10
MAX_DAILY_CLOUD_JOBS=20
MAX_DAILY_ESTIMATED_COST_USD=5
MAX_ACTIVE_JOBS_PER_CLIENT=2
STUDIO_SEGMENT_COUNT=5
STUDIO_SEGMENT_DURATION_SECONDS=6
RENDER_JOB_TIMEOUT_SECONDS=1800
TEMP_FILE_RETENTION_HOURS=24

# -------------------------
# FFmpeg
# Leave empty when FFmpeg is available through PATH.
# -------------------------
FFMPEG_PATH=
FFPROBE_PATH=

# -------------------------
# CPU and Worker Settings
# -------------------------
RENDER_WORKER_CONCURRENCY=1
AI_WORKER_CONCURRENCY=1
AI_MAX_QUEUE_SIZE=20
AI_JOB_TIMEOUT_SECONDS=1200
AI_MAX_RETRIES=2
AI_RETRY_BASE_DELAY_SECONDS=10
CPU_ENABLED=true
CPU_FALLBACK_ENABLED=true
CPU_DEVICE_ID=0

# -------------------------
# AI Model
# Do not place API keys in frontend variables.
# -------------------------
AI_PROVIDER=auto
AI_MODEL_NAME=Wan2.1
AI_MODEL_PATH=./storage/models/Wan2.1
# Absolute path to the complete Wan2.1 checkpoint directory containing the
# diffusion checkpoint, UMT5-XXL encoder, tokenizer files and Wan VAE.
# Keep the large model outside Git and do not copy it into this repository.
WAN_MODEL_PATH=
# Extracted official Wan2.1 source directory containing generate.py and wan/.
WAN_ENGINE_PATH=

# BYOK keys are accepted only from x-ai-provider-key and kept in memory.
ALLOW_BYOK=true
# Server-owned paid cloud credentials stay disabled unless explicitly enabled.
ALLOW_PAID_CLOUD=false
HF_ESTIMATED_COST_PER_SECOND_USD=
HF_TOKEN=
HF_VIDEO_MODEL=Wan-AI/Wan2.1-T2V-1.3B
AI_WORKER_URL=http://127.0.0.1:8100
AI_WORKER_CALLBACK_TOKEN=local-dev-ai-worker
# false enables configured real providers; true keeps the lifecycle simulator.
AI_WORKER_SIMULATOR=false
# Empty uses apps/ai-worker/.artifacts/tmp.
AI_TEMP_OUTPUT_DIR=
HF_GENERATION_TIMEOUT_SECONDS=900
HF_CONNECT_TIMEOUT_SECONDS=15
STORAGE_PROVIDER=local
# Empty uses storage/generated-videos inside the project runtime directory.
LOCAL_STORAGE_ROOT=
MAX_VIDEO_FILE_SIZE_MB=500
FFPROBE_PATH=
TEMP_ARTIFACT_RETENTION_HOURS=24
FAILED_ARTIFACT_RETENTION_HOURS=72
IMPORTED_VIDEO_RETENTION_HOURS=24
PROCESSED_VIDEO_RETENTION_HOURS=24
GENERATED_VIDEO_RETENTION_HOURS=24
MEDIA_CLEANUP_INTERVAL_MINUTES=60

# Credits are reserved before AI generation, captured on success and refunded
# on dispatch/worker failure or cancellation. Keep production starter balance 0.
CREDIT_SYSTEM_ENABLED=true
AUTH_REQUIRED=false
AUTH_ACCESS_TOKEN_MINUTES=15
AUTH_REFRESH_TOKEN_DAYS=30
AUTH_REQUIRE_EMAIL_VERIFICATION=false
AUTH_EMAIL_VERIFY_HOURS=24
AUTH_PASSWORD_RESET_MINUTES=30
APP_PUBLIC_URL=http://localhost:5173
AUTH_EMAIL_FROM=Brick-Maker <no-reply@example.com>
RESEND_API_KEY=
DEFAULT_CREDIT_BALANCE=0
VIDEO_GENERATION_BASE_CREDITS=10
VIDEO_GENERATION_CREDITS_PER_SECOND=2

# Optional external provider keys.
# Keep empty until needed.
OPENAI_API_KEY=
GOOGLE_API_KEY=

# -------------------------
# Logging and Monitoring
# -------------------------
LOG_LEVEL=info
LOG_DIRECTORY=./logs
ENABLE_REQUEST_LOGGING=true
ENABLE_RENDER_METRICS=true

# -------------------------
# Development
# -------------------------
ENABLE_API_DOCS=true
ENABLE_DEBUG_ROUTES=false

# Additional variables imported from .env_local.txt
APP_VERSION=
APP_ENV=
DEBUG=
HOST=
PORT=
SECRET_KEY=
JWT_SECRET=
JWT_ALGORITHM=
ACCESS_TOKEN_EXPIRE_MINUTES=
REFRESH_TOKEN_EXPIRE_DAYS=
DATABASE_HOST=
DATABASE_PORT=
DATABASE_NAME=
DATABASE_USER=
DATABASE_PASSWORD=
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=
CORS_ORIGINS=
GOOGLE_CLOUD_PROJECT=
GCP_PROJECT=
GCP_STORAGE_BUCKET=
GOOGLE_APPLICATION_CREDENTIALS=
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
